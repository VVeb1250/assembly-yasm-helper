{
	"name": "assembly-yasm-helper",
	"publisher": "VVeb1250",
	"displayName": "Assembly YASM Helper",
	"description": "Language support and smart autocomplete for YASM/NASM Assembler",
	"version": "2.0.0",
	"license": "MIT",
	"icon": "icon.png",
	"bin": {
		"assembly-yasm-lsp": "./bin/assembly-yasm-lsp.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/VVeb1250/assembly-yasm-helper.git"
	},
	"engines": {
		"vscode": "^1.48.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:assembly"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configurationDefaults": {
			"[assembly]": {
				"editor.wordBasedSuggestions": "off",
				"editor.tabCompletion": "off",
				"editor.autoClosingBrackets": "always",
				"editor.bracketPairColorization.enabled": true,
				"editor.insertSpaces": false,
				"editor.detectIndentation": false
			}
		},
		"configuration": {
			"title": "Assembly YASM Helper",
			"properties": {
				"assembly.compilerPath": {
					"type": "string",
					"default": "",
					"description": "Path to YASM/NASM compiler executable (e.g. /usr/bin/yasm or C:\\yasm\\yasm.exe)"
				},
				"assembly.compilerType": {
					"type": "string",
					"default": "yasm",
					"enum": [
						"yasm",
						"nasm"
					],
					"enumDescriptions": [
						"YASM Assembler",
						"NASM Assembler"
					],
					"description": "Assembler type to use for error checking"
				},
				"assembly.compilerFormat": {
					"type": "string",
					"default": "elf64",
					"enum": [
						"elf32",
						"elf64",
						"win32",
						"win64",
						"macho32",
						"macho64"
					],
					"enumDescriptions": [
						"ELF 32-bit (Linux x86)",
						"ELF 64-bit (Linux x64)",
						"PE 32-bit (Windows x86)",
						"PE 64-bit (Windows x64)",
						"Mach-O 32-bit (macOS x86)",
						"Mach-O 64-bit (macOS x64)"
					],
					"description": "Output format for the assembler"
				},
				"assembly.compilerDebugInfo": {
					"type": "string",
					"default": "dwarf2",
					"enum": [
						"none",
						"dwarf2",
						"stabs"
					],
					"enumDescriptions": [
						"No debug info",
						"DWARF2 debug info (-gdwarf2)",
						"Stabs debug info (-stabs)"
					],
					"description": "Debug info format"
				},
				"assembly.outputExtension": {
					"type": "string",
					"default": "o",
					"enum": [
						"o",
						"obj"
					],
					"description": "Output file extension"
				},
				"assembly.enableCompilerCheck": {
					"type": "boolean",
					"default": true,
					"description": "Enable compiler-based error checking on save"
				},
				"assembly.enableGoToDefinition": {
					"type": "boolean",
					"default": true,
					"description": "Enable Go to Definition (F12) for labels, variables, and procedures"
				},
				"assembly.enableDocumentSymbols": {
					"type": "boolean",
					"default": true,
					"description": "Enable Document Symbol outline (Outline panel and breadcrumb)"
				},
				"assembly.enableSignatureHelp": {
					"type": "boolean",
					"default": true,
					"description": "Enable Signature Help (operand hints while typing instructions)"
				},
				"assembly.tabTriggerCompletions": {
					"type": "boolean",
					"default": false,
					"description": "Show completion suggestions when Tab is pressed (off by default to avoid interfering with indentation)"
				},
				"assembly.tabSize": {
					"type": "number",
					"default": 8,
					"enum": [
						2,
						4,
						8
					],
					"enumDescriptions": [
						"2 spaces",
						"4 spaces",
						"8 spaces (classic assembly style)"
					],
					"description": "Indentation width (in spaces) for assembly files"
				}
			}
		},
		"keybindings": [
			{
				"key": "tab",
				"command": "tab",
				"when": "suggestWidgetVisible && editorLangId == assembly"
			}
		],
		"languages": [
			{
				"id": "assembly",
				"aliases": [
					"Assembly (YASM)",
					"Assembly",
					"assembly",
					"YASM",
					"NASM"
				],
				"extensions": [
					".asm",
					".s",
					".S"
				],
				"configuration": "./configs/language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "assembly",
				"scopeName": "source.asm",
				"path": "./syntaxes/assembly.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "assembly",
				"path": "./snippets.json"
			}
		],
		"semanticTokenScopes": [
			{
				"language": "assembly",
				"scopes": {
					"macro": [
						"entity.name.function.asm"
					],
					"register": [
						"entity.name.type.asm"
					]
				}
			}
		],
		"themes": [
			{
				"label": "Assembly Dark (YASM)",
				"id": "tasmDark",
				"uiTheme": "vs-dark",
				"path": "./Themes/tasmDark.tmTheme.json"
			},
			{
				"label": "Assembly Light (YASM)",
				"id": "tasmLight",
				"uiTheme": "vs",
				"path": "./Themes/tasmLight.tmTheme.json"
			},
			{
				"label": "Assembly High Contrast (YASM)",
				"id": "tasmHC",
				"uiTheme": "hc-black",
				"path": "./Themes/tasmHC.tmTheme.json"
			}
		]
	},
	"scripts": {
		"build": "esbuild ./out/extension.js --bundle --outfile=./dist/extension.js --external:vscode --platform=node --minify",
		"build:lsp": "esbuild ./lsp/server.js --bundle --outfile=./dist/server.js --platform=node --minify",
		"build:all": "npm run build && npm run build:lsp",
		"package": "npm run build:all && vsce package --main ./dist/extension.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.0.0",
		"@types/node": "^14.0.27",
		"@types/vscode": "^1.48.0",
		"@typescript-eslint/eslint-plugin": "^3.8.0",
		"@typescript-eslint/parser": "^3.8.0",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.3",
		"eslint": "^7.6.0",
		"glob": "^7.1.6",
		"mocha": "^8.0.1",
		"typescript": "^3.9.7"
	},
	"dependencies": {
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.12"
	}
}
