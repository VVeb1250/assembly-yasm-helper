{
	"name": "assembly-yasm-helper",
	"publisher": "VVeb1250",
	"displayName": "Assembly YASM Helper",
	"description": "Language support and smart autocomplete for YASM/NASM Assembler",
	"version": "1.0.4",
	"repository": {
		"type": "git",
		"url": "https://github.com/VVeb1250/assembly-yasm-helper.git"
	},
	"engines": {
		"vscode": "^1.48.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:assembly"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configurationDefaults": {
			"[assembly]": {
				"editor.wordBasedSuggestions": "off"
			}
		},
		"keybindings": [
			{
				"key": "tab",
				"command": "tab",
				"when": "suggestWidgetVisible && editorLangId == assembly"
			}
		],
		"languages": [
			{
				"id": "assembly",
				"aliases": [
					"Assembly (YASM)",
					"Assembly",
					"assembly",
					"YASM",
					"NASM"
				],
				"extensions": [
					".asm",
					".s",
					".S"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "assembly",
				"scopeName": "source.asm",
				"path": "./syntaxes/assembly.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "assembly",
				"path": "./snippets.json"
			}
		],
		"themes": [
			{
				"label": "Assembly Dark (YASM)",
				"id": "tasmDark",
				"uiTheme": "vs-dark",
				"path": "./themes/tasmDark.tmTheme.json"
			},
			{
				"label": "Assembly Light (YASM)",
				"id": "tasmLight",
				"uiTheme": "vs",
				"path": "./themes/tasmLight.tmTheme.json"
			},
			{
				"label": "Assembly High Contrast (YASM)",
				"id": "tasmHC",
				"uiTheme": "hc-black",
				"path": "./themes/tasmHC.tmTheme.json"
			}
		]
	},
	"scripts": {
    	"build": "esbuild ./out/extension.js --bundle --outfile=./dist/extension.js --external:vscode --platform=node --minify",
    	"package": "npm run build && vsce package"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.0.0",
		"@types/node": "^14.0.27",
		"@types/vscode": "^1.48.0",
		"@typescript-eslint/eslint-plugin": "^3.8.0",
		"@typescript-eslint/parser": "^3.8.0",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.3",
		"eslint": "^7.6.0",
		"glob": "^7.1.6",
		"mocha": "^8.0.1",
		"typescript": "^3.9.7",
		"vsce": "^1.78.0"
	},
	"__metadata": {
		"installedTimestamp": 1771779188107,
		"targetPlatform": "undefined",
		"size": 6466113
	}
}
