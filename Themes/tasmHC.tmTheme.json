{
    "type": "dark",
    "colors": {
        "editor.background": "#000000",
        "editor.foreground": "#d4d4d4",
        "editorIndentGuide.background": "#404040",
        "editorRuler.foreground": "#333333",
        "activityBarBadge.background": "#007acc",
        "sideBarTitle.foreground": "#bbbbbb",
        "contrastActiveBorder": "#FFFFFF",
        "contrastBorder": "#DEE7F2"
    },
    "tokenColors": [
        {
            "scope": "comment",
            "settings": {
                "foreground": "#7AA04B"
            }
        },
        {
            "scope": "string",
            "settings": {
                "foreground": "#CE9178"
            }
        },
        {
            "scope": "string.quoted.single.asm",
            "settings": {
                "foreground": "#5C9962"
            }
        },
        {
            "scope": "string.quoted.double.asm",
            "settings": {
                "foreground": "#D28E8E"
            }
        },
        {
            "scope": "constant.character.escape.asm",
            "settings": {
                "foreground": "#D7BA7D"
            }
        },
        {
            "scope": "constant.numeric.asm",
            "settings": {
                "foreground": "#A3D98C"
            }
        },
        {
            "scope": "keyword.control.asm",
            "settings": {
                "foreground": "#569CD6"
            }
        },
        {
            "scope": "keyword.control.preprocessor.asm",
            "settings": {
                "foreground": "#C586C0"
            }
        },
        {
            "scope": "keyword.operator.asm",
            "settings": {
                "foreground": "#B7EDF1"
            }
        },
        {
            "scope": "storage.type.asm",
            "settings": {
                "foreground": "#569CD6"
            }
        },
        {
            "scope": "storage.modifier.asm",
            "settings": {
                "foreground": "#C586C0"
            }
        },
        {
            "scope": "variable.other.register.asm",
            "settings": {
                "foreground": "#A2C3BB"
            }
        },
        {
            "scope": "variable.name.asm",
            "settings": {
                "foreground": "#9CDCFE"
            }
        },
        {
            "scope": "support.function.label.asm",
            "settings": {
                "foreground": "#DCDCAA",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "entity.name.function.asm",
            "settings": {
                "foreground": "#DCDCAA"
            }
        },
        {
            "scope": "entity.name.section.asm",
            "settings": {
                "foreground": "#4EC9B0"
            }
        },
        {
            "scope": "entity.name.constant.asm",
            "settings": {
                "foreground": "#DCDCAA"
            }
        },
        {
            "scope": "variable.language.asm",
            "settings": {
                "foreground": "#C8A8FF",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "punctuation.separator.asm",
            "settings": {
                "foreground": "#808080"
            }
        }
