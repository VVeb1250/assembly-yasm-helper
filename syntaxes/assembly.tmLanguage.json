{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Assembly",
	"scopeName": "source.asm",

	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#labels" },
		{ "include": "#directives" },
		{ "include": "#instructions" },
		{ "include": "#registers" },
		{ "include": "#numbers" },
		{ "include": "#punctuation" },
		{ "include": "#operators" },
		{ "include": "#variables" }
	],
	"repository": {

		"comments": {
			"patterns": [
			{
				"name": "comment.line.asm",
				"match": "[;#].*$"
			},
			{
				"name": "comment.block.asm",
				"begin": "/\\*",
				"end": "\\*/"
			}
			]
		},

		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.asm",
					"begin": "\"",
					"end": "\"|\\n",
					"patterns": [
						{
							"name": "constant.character.escape.asm",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.asm",
					"begin": "'",
					"end": "'|\\n",
					"patterns": [
						{
							"name": "constant.character.escape.asm",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.other.asm",
					"begin": "`",
					"end": "`|\\n",
					"patterns": [
						{
							"name": "constant.character.escape.asm",
							"match": "\\\\."
						}
					]
				}
			]
		},

		"labels": {
			"patterns": [
				{
					"match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:",
					"captures": {
						"1": {
							"name": "support.function.label.asm"
						}
					}
				}
			]
		},

		"directives": {
			"patterns": [
				{
					"match": "(?i)\\b(section|segment)\\b",
					"name": "keyword.control.asm"
				},
				{
					"match": "(?i)\\b(global|extern|align|bits|default|times)\\b",
					"name": "keyword.control.asm"
				},
				{
					"match": "(?i)\\b(db|dw|dd|dq|dt|resb|resw|resd|resq|equ)\\b",
					"name": "keyword.control.asm"
				},
				{
					"match": "(?i)\\b(byte|word|dword|qword|tbyte|ptr)\\b",
					"name": "keyword.control.asm"
				}
			]
		},

		"instructions": {
			"patterns": [
				{
					"name": "keyword.control.asm",
					"match": "(?i)\\b(mov|lea|push|pop|add|sub|mul|imul|div|idiv|inc|dec|and|or|xor|not|test|cmp|jmp|je|jne|jg|jge|jl|jle|ja|jb|call|ret|int|syscall|sysret|nop|hlt)\\b"
				}
			]
		},

		"registers": {
			"patterns": [
				{
					"name": "variable.name.asm",
					"match": "(?i)\\b(al|bl|cl|dl|ah|bh|ch|dh)\\b"
				},
				{
					"name": "variable.name.asm",
					"match": "(?i)\\b(ax|bx|cx|dx|sp|bp|si|di)\\b"
				},
				{
					"name": "variable.name.asm",
					"match": "(?i)\\b(eax|ebx|ecx|edx|esp|ebp|esi|edi)\\b"
				},
				{
					"name": "variable.name.asm",
					"match": "(?i)\\b(rax|rbx|rcx|rdx|rsp|rbp|rsi|rdi|rip)\\b"
				},
				{
					"name": "variable.name.asm",
					"match": "(?i)\\b(r8|r9|r10|r11|r12|r13|r14|r15)\\b"
				}
			]
		},

		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.asm",
					"match": "\\b0x[0-9A-Fa-f]+\\b"
				},
				{
					"name": "constant.numeric.asm",
					"match": "\\b[0-9]+\\b"
				}
			]
		},

		"punctuation": {
			"patterns": [
				{
					"match": "[\\[\\]\\(\\)\\{\\}]",
					"name": "punctuation.separator.asm"
				},
				{
					"match": "[,:]",
					"name": "punctuation.separator.asm"
				}
			]
		},

		"operators": {
			"match": "[+\\-*/<>|&^=~%]",
			"name": "keyword.operator.asm"
		},

		"variables": {
			"match": "[A-Za-z_][A-Za-z0-9_]*",
			"name": "variable.name.asm"
		}

	}

}